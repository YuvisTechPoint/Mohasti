# Site URL (production domain — used for sitemap & metadata)
NEXT_PUBLIC_SITE_URL=https://mohasti.com

# Firebase client (browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server — required in production)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Razorpay (required in production for online payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# Optional: allow demo/simulated payments (never enable in production)
# ALLOW_DEMO_PAYMENTS=false

# Deploy checklist:
# 1. Enable Google sign-in in Firebase Console (Authentication → Google)
# 2. Add authorized domains: localhost + production domain
# 3. Deploy firestore.rules from this repo
# 4. Create Firestore composite indexes if prompted for orders queries
# 5. Configure Razorpay webhook → POST /api/payments/webhook (payment.captured)
