# Site URL (production domain — used for sitemap & metadata)
NEXT_PUBLIC_SITE_URL=https://mohasti.com

# Firebase client (browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Google OAuth (Firebase Google sign-in — set in Firebase Console too)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Firebase Admin (server — required in production)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Razorpay (required in production for online payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# Optional: allow demo/simulated payments (never enable in production)
# ALLOW_DEMO_PAYMENTS=false

# Deploy checklist:
# 1. Enable Google sign-in in Firebase Console (Authentication → Google)
# 2. Add ALL domains where the app runs under Authentication → Settings → Authorized domains:
#    - localhost
#    - mohasti.vercel.app
#    - mohasti.com (when custom domain is live)
#    - *.vercel.app preview URLs if you test PR deploys (add each hostname Vercel shows)
# 3. Set the same Firebase env vars on Vercel (Project → Settings → Environment Variables)
# 4. Deploy firestore.rules from this repo
# 5. Create Firestore composite indexes if prompted for orders queries
# 6. Configure Razorpay webhook → POST /api/payments/webhook (payment.captured)
